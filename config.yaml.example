server:
  host: "127.0.0.1"
  port: 8080

log:
  level: "info"
  # level: "debug"

audit:
  enabled: true
  server: "192.168.1.100"
  port: 9000
  buffer_size: 1000

scanner:
  hash:
    # algorithm: "sha256"
    # algorithm: "md5"
    algorithm: "xxhash64"
  file:
    include_paths:
      - /
    exclude_paths:
      # ========== 虚拟/临时文件系统==========
      - /proc
      - /sys
      - /dev
      - /tmp
      - /var/tmp
      - /run
      - /mnt
      - /media
      
      # ========== 系统高频写入目录==========
      - /var/log
      - /var/cache
      - /var/mail
      - /var/spool
      - /var/lib/docker
      - /var/lib/containerd
      - /var/lib/systemd
      
      # ========== 内核模块==========
      - /usr/lib/modules
      - /lib/modules
      - /usr/src
      
      # ========== 应用缓存和构建目录==========
      # 通用
      - "**/node_modules"
      - "**/.git"
      - "**/.cache"
      - "**/build"
      - "**/dist"
      - "**/unpackage"
      - "**/vendor"
      - "**/__pycache__"
      - "**/.idea"
      - "**/.vscode"
      
      # ========== Web 应用特定==========
      - "**/cache"
      - "**/logs"
      - "**/tmp"
      - "**/temp"
      - "**/uploads/tmp"
      
      # ========== 用户缓存目录 ==========
      - /root/.cache
      - /root/.npm
      - /root/.local
      - /home/*/.cache
      - /home/*/.npm
      - /home/*/.local
      - /home/*/.gradle
      - /home/*/.m2
      
      # ========== 其他高频变化目录 ==========
      - /var/run
      - /var/lock
      - /opt/*/cache
      - /opt/*/logs
    fast_hash: true
    fast_hash_size: 100MB
    fast_hash_chunk: 2MB
  process:
    interval: 300 # seconds

storage:
  data_dir: "/var/lib/sysmonitord"
  process_system_file: "process_system.data"
  file_system_file: "file_system.data"
  dubious_file_list_file: "dubious_files.data"
  dubious_process_list_file: "dubious_processes.data"

notification:
  interval: 5 # minutes
  email:
    enabled: true
    recipients:
      -
    smtp:
      server: smtp.example.com
      port: 465
      username: sysmonitord@example.com
      password: "${SYSMONITORD_SMTP_PASSWORD}"

script:
  enabled: true
  dir: "/etc/sysmonitord/scripts"
  timeout_ms: 5000
  events:
    system_start:
      - startup.js
    file_change:
      - file-change.js
    dubious_file:
      - dubious-file.js
    dubious_process:
      - dubious-process.js
    error:
      - error.js

ai:
  enabled: true
  api_url: "https://api.openai.com/v1/chat/completions"
  api_key: "${SYSMONITORD_AI_API_KEY}"
  model: "gpt-4o-mini"
  timeout: 120
  report_dir: "/var/lib/sysmonitord/reports"
  # 单个配置文件最大读取字节数，默认示例为 200KB
  max_file_size: 204800
  # 本次 AI 分析最大总读取字节数，默认示例为 2MB
  max_total_size: 2097152
  # 本功能会将以下路径和文件内容明文发送给 AI
  include_paths:
    # 系统基础配置
    - /etc/ssh/sshd_config
    - /etc/sudoers
    - /etc/passwd
    - /etc/group
    - /etc/login.defs
    - /etc/security/limits.conf
    - /etc/sysctl.conf
    # Nginx
    - /etc/nginx/nginx.conf
    - /etc/nginx/conf.d/default.conf
    # Debian/Ubuntu 额外关注：
    - /etc/nginx/sites-available/default
    # Node.js
    # 注：Node.js 本身无系统级主配置，主要关注 npm 全局配置与运行环境
    - /etc/npmrc
    - /usr/local/etc/npmrc
    - /etc/profile.d/nodejs.sh
    # Java (OpenJDK/JRE)
    # 注：不同 JDK 版本和安装方式路径差异较大，建议根据实际 JAVA_HOME 调整
    - /etc/java/java.conf
    - /etc/profile.d/java.sh
    - /usr/lib/jvm/default-java/jre/lib/security/java.security
    - /usr/lib/jvm/default-java/lib/security/java.security
    # PHP
    # RHEL/CentOS 系列：
    - /etc/php.ini
    - /etc/php-fpm.conf
    - /etc/php-fpm.d/www.conf
    # Debian/Ubuntu 系列（请将 8.2 替换为实际版本号，如 7.4、8.1、8.3）：
    - /etc/php/8.2/fpm/php.ini
    - /etc/php/8.2/cli/php.ini
    - /etc/php/8.2/fpm/pool.d/www.conf
    # PostgreSQL
    # RHEL/CentOS/Rocky 默认数据目录：
    - /var/lib/pgsql/data/postgresql.conf
    - /var/lib/pgsql/data/pg_hba.conf
    # Debian/Ubuntu 系列（请将 16 替换为实际主版本号，如 14、15）：
    - /etc/postgresql/16/main/postgresql.conf
    - /etc/postgresql/16/main/pg_hba.conf
    # MySQL / MariaDB
    # RHEL/CentOS/通用：
    - /etc/my.cnf
    - /etc/my.cnf.d/server.cnf        # MariaDB
    # Debian/Ubuntu：
    - /etc/mysql/my.cnf
    - /etc/mysql/mysql.conf.d/mysqld.cnf
    - /etc/mysql/conf.d/mysql.cnf